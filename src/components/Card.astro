---
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"blog">;

const { variant: Heading = "h2", id, data, filePath, body } = Astro.props;

const { title, description, ...props } = data;

// Auto-extract preview from body content
function getPreview(body: string, maxLength: number = 150): string {
  // Remove markdown syntax and get plain text
  let text = body
    .replace(/!\[.*?\]\(.*?\)/g, '') // Remove images
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1') // Replace links with text
    .replace(/[#*_`]/g, '') // Remove markdown formatting
    .replace(/<[^>]+>/g, '') // Remove HTML tags
    .replace(/\n+/g, ' ') // Replace newlines with spaces
    .trim();
  
  // Get first sentence or up to maxLength
  const firstSentence = text.split(/[.!?]/)[0];
  if (firstSentence && firstSentence.length <= maxLength) {
    return firstSentence + '.';
  }
  
  // Truncate if needed
  if (text.length > maxLength) {
    return text.substring(0, maxLength).trim() + '...';
  }
  
  return text;
}

const preview = description || getPreview(body || '');
---

<li class="my-6">
  <a
    href={getPath(id, filePath)}
    class:list={[
      "inline-block text-lg font-medium text-accent",
      "decoration-dashed underline-offset-4 hover:underline",
      "focus-visible:no-underline focus-visible:underline-offset-0",
    ]}
  >
    <Heading
      style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
    >
      {title}
    </Heading>
  </a>
  <Datetime {...props} />
  {preview && <p class="mt-2 text-sm opacity-80 line-clamp-2">{preview}</p>}
</li>
